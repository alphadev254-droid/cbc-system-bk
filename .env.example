NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME"

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cbc_platform

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Email (SendGrid or SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
MAIL_FROM_ADDRESS=noreply@yourdomain.co.ke
MAIL_FROM_NAME=CBC Platform

# SMS (Africa's Talking — legacy)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
AT_SENDER_ID=CBC-Platform

# SMS — school admin credentials (generic HTTP API, e.g. TextSMS)
# When TEXTSMS_ENABLED=true, POST JSON to TEXTSMS_API_URL with Bearer TEXTSMS_API_KEY
TEXTSMS_ENABLED=false
TEXTSMS_API_URL=https://your-sms-provider.example.com/send
TEXTSMS_API_KEY=
TEXTSMS_SENDER_ID=CBC
# Optional template: use {school} {email} {password} {url}
# TEXTSMS_MESSAGE_TEMPLATE=CBC: School {school}. Login {url} Email {email} Password {password}

# Storage
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=2097152

# Seed — system admin credentials (only used on first run)
SEED_ADMIN_EMAIL=admin@yourdomain.co.ke
SEED_ADMIN_PASSWORD=ChangeMe@2024!
SEED_ADMIN_NAME=System Administrator

# App URL (for email links)
APP_URL=http://localhost:5000
# Login page URL included in SMS to new school admins
APP_LOGIN_URL=http://localhost:5173/login
CORS_ORIGIN=http://localhost:3000
