# ─── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MySQL (Prisma) — create DB first: CREATE DATABASE cbc_platform; ─────────
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/cbc_platform"

# ─── JWT (use long random strings in production) ──────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-at-least-32-chars

# ─── Public URL (emails, reset links, upload URLs) ──────────────────────────
APP_URL=http://localhost:5000

# ─── CORS (comma-separated origins or * for dev) ─────────────────────────────
CORS_ORIGIN=*

# ─── Seed script (first SYSTEM_ADMIN user) ──────────────────────────────────
SEED_ADMIN_EMAIL=admin@cbcplatform.co.ke
SEED_ADMIN_PASSWORD=ChangeMe@2024!
SEED_ADMIN_NAME=System Administrator

# ─── Africa's Talking SMS (optional — leave blank if unused) ───────────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# ─── SMTP (optional — only needed when sending mail) ───────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=CBC Platform
MAIL_FROM_ADDRESS=noreply@example.com
